# Secrets
.streamlit/secrets.toml
.env
.claude/settings.local.json

# Python
__pycache__/
*.pyc
.venv/
venv/

# Logs (runtime-generated)
logs/

# macOS metadata
.DS_Store

# Distribution boundary — marked/restricted source material stays local, never committed
wiki/sources/raw/local/

# Future unit-internal wiki pages (ship only in NIPR bundle, never to GitHub)
wiki/internal/

# Bundle output
dist/

# Obsidian editor config (per-user; workspace.json churns every session)
wiki/.obsidian/

# Eval run reports (nondeterministic; the question set IS committed)
evals/results-*.md

# Vector store (large binary files — rebuild with ingest.py)
# Uncomment next line if you want to exclude from git:
# vectorstore/
